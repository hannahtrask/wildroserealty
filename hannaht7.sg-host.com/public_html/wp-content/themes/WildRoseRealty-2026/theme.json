  "styles": {
    "color": {
      "background": "#ffffff",
      "text": "#1a1a1a"
    },
    "typography": {
      "fontFamily": "'Open Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif",
      "fontSize": "1rem",
      "lineHeight": "1.6"
    },
    "elements": {
      "heading": {
        "typography": {
          "fontFamily": "'Merriweather', Georgia, serif",
          "fontWeight": "600",
          "lineHeight": "1.2"
        }
      },
      "link": {
        "color": {
          "text": "#8B6F47"
        },
        ":hover": {
          "color": {
            "text": "#6B5437"
          }
        }
      }
    },
    "blocks": {
      "core/button": {
        "color": {
          "background": "#8B6F47",
          "text": "#ffffff"
        },
        "spacing": {
          "padding": {
            "top": "1rem",
            "right": "2rem",
            "bottom": "1rem",
            "left": "2rem"
          }
        },
        ":hover": {
          "color": {
            "background": "#6B5437"
          }
        }
      },
      "core/heading": {
        "spacing": {
          "margin": {
            "bottom": "1rem"
          }
        }
      },
      "core/paragraph": {
        "spacing": {
          "margin": {
            "bottom": "1rem"
          }
        }
      },
      "core/image": {
        "spacing": {
          "margin": {
            "bottom": "1.5rem"
          }
        }
      }
    }
